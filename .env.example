# ============================================================
# PORTAL CURY – VARIÁVEIS DE AMBIENTE
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Porta em que o servidor vai rodar
PORT=3000

# Ambiente (production | development)
NODE_ENV=production

# Chave secreta para JWT — OBRIGATÓRIO em produção
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=TROQUE_ESTA_CHAVE_POR_UMA_STRING_ALEATORIA_LONGA

# Diretório do banco SQLite (padrão: ./data)
# Em produção com EasyPanel/Docker, aponte para o volume persistente:
# DATA_DIR=/data
DATA_DIR=

# ============================================================
# As configurações abaixo são gerenciadas pelo painel admin.
# Você não precisa defini-las aqui — ficam salvas no banco.
# Documente aqui apenas para referência de onboarding:
# ============================================================

# WhatsApp (configurado no admin > Configurações)
# WHATSAPP_NUMBER=5521999999999
# WHATSAPP_MESSAGE=Olá! Quero saber mais sobre os empreendimentos Cury.

# Email SMTP (configurado no admin > Configurações > Email)
# EMAIL_ENABLED=true
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_SECURE=false
# EMAIL_SMTP_USER=seu@email.com
# EMAIL_SMTP_PASS=sua_senha_de_app

# Evolution API (configurado no admin > Configurações > Evolution API)
# EVOLUTION_ENABLED=true
# EVOLUTION_URL=https://evo.seudominio.com
# EVOLUTION_INSTANCE=nome_da_instancia
# EVOLUTION_APIKEY=sua_api_key
# EVOLUTION_PHONE=5521999999999

# Webhook (configurado no admin > Configurações > Webhook)
# WEBHOOK_ENABLED=true
# WEBHOOK_URL=https://seu-webhook.com/endpoint
# WEBHOOK_SECRET=chave_secreta_hmac

# Google Ads (configurado no admin > Configurações > Rastreamento)
# GADS_TAG_ID=AW-123456789
# GADS_CONVERSION_LABEL=AbCdEfGhIjKl

# Google Tag Manager (configurado no admin > Configurações > Rastreamento)
# GTM_ID=GTM-XXXXXXX
