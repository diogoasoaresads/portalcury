# ============================================================
# CENTRAL CURY VENDAS – VARIÁVEIS DE AMBIENTE
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Porta em que o servidor vai rodar
PORT=3000

# Chave secreta para JWT (OBRIGATÓRIO: troque por uma string aleatória longa)
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=TROQUE_ESTA_CHAVE_POR_UMA_STRING_ALEATORIA_LONGA

# Ambiente
NODE_ENV=production

# ── PERSISTÊNCIA DO BANCO DE DADOS ─────────────────────────────────────────
# Caminho onde o arquivo centralcuryvendas.db será gravado.
# IMPORTANTE: aponte para um volume persistente no seu provedor de deploy.
# Se não definir, o banco fica em ./data/ dentro do container e SOME no redeploy.
#
# EasyPanel / Railway / Render:
#   1. Crie um volume persistente montado em /data
#   2. Defina DATA_DIR=/data nas variáveis de ambiente do serviço
#
# VPS com PM2:
#   Defina um caminho fora da pasta do projeto, ex: /var/lib/centralcuryvendas
#   e adicione DATA_DIR=/var/lib/centralcuryvendas no ecosystem.config.js (env_production)
#
DATA_DIR=/data
