  </div>

  <!-- Success Modal -->
  <div class="modal" id="successModal" role="dialog" aria-modal="true">
    <div class="modal__backdrop"></div>
    <div class="modal__box">
      <div class="modal__icon">✓</div>
      <h3>Solicitação Enviada!</h3>
      <p>Recebemos seu contato. Um especialista entrará em contato em breve pelo seu WhatsApp!</p>
      <button class="btn btn--primary" id="closeModal">Fechar</button>
    </div>
  </div>

  <script src="/js/main.js"></script>
  <script src="/js/gallery.js"></script>
  <% if (tracking.gads_tag_id && tracking.gads_conversion_label) { %>
  <script>
  // Dispara conversão do Google Ads quando lead for enviado com sucesso
  (function(){
    var orig = window.showModal;
    if (typeof orig === 'function') {
      window.showModal = function() {
        orig();
        if (typeof gtag !== 'undefined' && window._GADS) {
          gtag('event','conversion',{'send_to': window._GADS});
        }
      };
    }
  })();
  </script>
  <% } %>
</body>
</html>
