<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title><%= emp.seoTitle %></title>
  <meta name="description" content="<%= emp.seoDesc %>" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://www.portalcury.com.br/empreendimentos/<%= emp.slug %>" />

  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://www.portalcury.com.br/empreendimentos/<%= emp.slug %>" />
  <meta property="og:title" content="<%= emp.seoTitle %>" />
  <meta property="og:description" content="<%= emp.seoDesc %>" />
  <meta property="og:image" content="<%= emp.heroImage %>" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="<%= emp.heroImage %>" />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Residence",
    "name": "<%= emp.name %>",
    "description": "<%= emp.seoDesc %>",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "<%= emp.address %>",
      "addressLocality": "<%= emp.city %>",
      "addressRegion": "RJ",
      "addressCountry": "BR"
    },
    "image": "<%= emp.heroImage %>",
    "url": "https://www.portalcury.com.br/empreendimentos/<%= emp.slug %>"
  }
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/empreendimento.css" />

  <% if (tracking.gtm_id) { %>
  <!-- Google Tag Manager -->
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','<%= tracking.gtm_id %>');</script>
  <!-- End Google Tag Manager -->
  <% } %>

  <% if (tracking.gads_tag_id) { %>
  <!-- Google Ads / gtag.js -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=<%= tracking.gads_tag_id %>"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','<%= tracking.gads_tag_id %>');<% if (tracking.gads_conversion_label) { %>window._GADS='<%= tracking.gads_tag_id %>/<%= tracking.gads_conversion_label %>';<% } %></script>
  <!-- End Google Ads -->
  <% } %>

  <% if (tracking.custom_head_code) { %>
  <%- tracking.custom_head_code %>
  <% } %>
</head>
<body>

  <% if (tracking.gtm_id) { %>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=<%= tracking.gtm_id %>" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->
  <% } %>
  <% if (tracking.custom_body_code) { %>
  <%- tracking.custom_body_code %>
  <% } %>

  <!-- Header -->
  <header class="header" id="header">
    <div class="container header__inner">
      <a href="/" class="header__logo" aria-label="Portal Cury">
        <img src="/images/logo-cury.png" class="logo__img" alt="Portal Cury" height="36">
      </a>
      <nav class="header__nav">
        <a href="/">Início</a>
        <a href="/#empreendimentos">Empreendimentos</a>
        <a href="/#vantagens">Vantagens</a>
        <a href="#contato">Contato</a>
      </nav>
      <button class="header__menu-btn" id="menuBtn" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="container breadcrumb__inner">
      <a href="/">Início</a>
      <span>/</span>
      <a href="/#empreendimentos">Empreendimentos</a>
      <span>/</span>
      <span><%= emp.name %></span>
    </div>
  </nav>

  <!-- Hero -->
  <section class="emp-hero">
    <div class="emp-hero__img" style="background-image: url('<%= emp.heroImage %>')">
      <div class="emp-hero__overlay"></div>
    </div>
    <div class="container emp-hero__content">
      <div class="emp-hero__text">
        <div class="emp-hero__badges">
          <span class="emp-badge <%= emp.badgeClass %>"><%= emp.badge %></span>
          <span class="emp-badge emp-badge--bairro">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <%= emp.bairro %><% if (emp.city !== 'Rio de Janeiro') { %>, <%= emp.city %><% } %>
          </span>
        </div>
        <h1><%= emp.name %></h1>
        <p class="emp-hero__tagline"><%= emp.tagline %></p>
        <% if (emp.price) { %><p class="emp-hero__price"><%= emp.price %></p><% } %>
        <div class="emp-hero__details">
          <div class="emp-detail">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <span><%= emp.details.rooms %></span>
          </div>
          <div class="emp-detail">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/></svg>
            <span><%= emp.details.area %></span>
          </div>
          <div class="emp-detail">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span><%= emp.details.delivery %></span>
          </div>
          <div class="emp-detail">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            <span><%= emp.details.units %></span>
          </div>
        </div>
      </div>
      <div class="emp-hero__form-wrap">
        <div class="hero__form-card">
          <p class="form-card__eyebrow">Interesse neste empreendimento?</p>
          <h2 class="form-card__title">Fale com um Especialista</h2>
          <p class="form-card__subtitle">Resposta em até 5 minutos</p>
          <form class="lead-form" id="heroForm" novalidate>
            <input type="hidden" name="interest" value="<%= emp.interestValue %>" />
            <div class="form-group">
              <label for="h-name">Nome completo *</label>
              <input type="text" id="h-name" name="name" placeholder="Seu nome" required autocomplete="name" />
            </div>
            <div class="form-group">
              <label for="h-phone">WhatsApp / Telefone *</label>
              <input type="tel" id="h-phone" name="phone" placeholder="(21) 9 0000-0000" required autocomplete="tel" />
            </div>
            <div class="form-group">
              <label for="h-email">E-mail</label>
              <input type="email" id="h-email" name="email" placeholder="seu@email.com" autocomplete="email" />
            </div>
            <button type="submit" class="btn btn--primary btn--full">Quero Minha Simulação Grátis</button>
            <p class="form-card__privacy">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
              Seus dados estão protegidos.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="emp-gallery" aria-label="Galeria de fotos">
    <div class="container">
      <div class="gallery-grid">
        <div class="gallery-main" id="galleryMain">
          <img src="<%= emp.gallery[0] %>" alt="<%= emp.name %> - foto principal" loading="eager" />
        </div>
        <div class="gallery-thumbs" id="galleryThumbs">
          <% emp.gallery.forEach(function(img, i) { %>
          <div class="gallery-thumb <%= i === 0 ? 'active' : '' %>" data-src="<%= img %>">
            <img src="<%= img %>" alt="<%= emp.name %> - foto <%= i + 1 %>" loading="lazy" />
          </div>
          <% }); %>
        </div>
      </div>
    </div>
  </section>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Visualizar foto">
    <button class="lightbox__close" id="lightboxClose" aria-label="Fechar">✕</button>
    <button class="lightbox__prev" id="lightboxPrev" aria-label="Anterior">‹</button>
    <img src="" alt="" id="lightboxImg" />
    <button class="lightbox__next" id="lightboxNext" aria-label="Próxima">›</button>
  </div>

  <!-- Content: About + Features + Nearby -->
  <section class="emp-content">
    <div class="container emp-content__grid">
      <div class="emp-content__main">

        <!-- About -->
        <div class="content-card">
          <h2 class="content-card__title">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
            Sobre o Empreendimento
          </h2>
          <p><%= emp.description %></p>
          <div class="emp-address">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <%= emp.address %>
          </div>
        </div>

        <!-- Features -->
        <div class="content-card">
          <h2 class="content-card__title">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            Lazer e Infraestrutura
          </h2>
          <ul class="features-list">
            <% emp.features.forEach(function(f) { %>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              <%= f %>
            </li>
            <% }); %>
          </ul>
        </div>

        <!-- Nearby -->
        <div class="content-card">
          <h2 class="content-card__title">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            O Que Tem Por Perto
          </h2>
          <div class="nearby-grid">
            <% emp.nearby.forEach(function(n) { %>
            <div class="nearby-item">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 8 12 12 14 14"/></svg>
              <%= n %>
            </div>
            <% }); %>
          </div>
        </div>

        <!-- Financing -->
        <div class="content-card content-card--financing">
          <h2 class="content-card__title">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            Formas de Financiamento
          </h2>
          <div class="financing-tags">
            <% emp.financing.forEach(function(f) { %>
            <span class="fin-tag"><%= f %></span>
            <% }); %>
          </div>
        </div>
      </div>

      <!-- Sidebar form -->
      <aside class="emp-content__sidebar">
        <div class="sidebar-form-card" id="contato">
          <p class="form-card__eyebrow">Garanta sua Unidade</p>
          <h3 class="form-card__title">Fale com um Especialista</h3>
          <p class="form-card__subtitle">Preencha e receba atendimento agora</p>
          <form class="lead-form" id="sidebarForm" novalidate>
            <input type="hidden" name="interest" value="<%= emp.interestValue %>" />
            <div class="form-group">
              <label for="sb-name">Nome completo *</label>
              <input type="text" id="sb-name" name="name" placeholder="Seu nome" required autocomplete="name" />
            </div>
            <div class="form-group">
              <label for="sb-phone">WhatsApp / Telefone *</label>
              <input type="tel" id="sb-phone" name="phone" placeholder="(21) 9 0000-0000" required autocomplete="tel" />
            </div>
            <div class="form-group">
              <label for="sb-email">E-mail</label>
              <input type="email" id="sb-email" name="email" placeholder="seu@email.com" autocomplete="email" />
            </div>
            <div class="form-group">
              <label for="sb-msg">Mensagem</label>
              <textarea id="sb-msg" name="message" rows="3" placeholder="Tenho FGTS disponível, quero simular..."></textarea>
            </div>
            <button type="submit" class="btn btn--primary btn--full btn--lg">Solicitar Atendimento</button>
            <a href="https://wa.me/5521967019390?text=Olá!%20Tenho%20interesse%20no%20<%= encodeURIComponent(emp.name) %>" target="_blank" rel="noopener" class="btn btn--whatsapp btn--full" style="margin-top:10px;text-decoration:none">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Chamar no WhatsApp
            </a>
            <p class="form-card__privacy">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
              Seus dados estão protegidos.
            </p>
          </form>
        </div>

        <!-- Quick contact -->
        <div class="sidebar-contact">
          <span>Seg a Sáb · 8h às 18h</span>
        </div>
      </aside>
    </div>
  </section>

  <!-- Other developments -->
  <section class="outros-empreendimentos">
    <div class="container">
      <div class="section-header">
        <span class="section-header__eyebrow">Explore mais opções</span>
        <h2 class="section-header__title">Outros Empreendimentos</h2>
      </div>
      <div class="outros-grid">
        <% others.forEach(function(o) { %>
        <a href="/empreendimentos/<%= o.slug %>" class="outro-card">
          <div class="outro-card__img">
            <img src="<%= o.heroImage %>" alt="<%= o.name %>" loading="lazy" />
          </div>
          <div class="outro-card__body">
            <span class="outro-card__bairro"><%= o.bairro %></span>
            <h3><%= o.name %></h3>
            <span class="outro-card__rooms"><%= o.details.rooms %></span>
          </div>
        </a>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__brand">
        <a href="/" class="header__logo footer__logo">
          <img src="/images/logo-cury.png" class="logo__img" alt="Portal Cury" height="36">
        </a>
        <p>Realizando o sonho da casa própria há mais de 30 anos no Rio de Janeiro e Niterói.</p>
      </div>
      <div class="footer__links">
        <h4>Empreendimentos</h4>
        <ul>
          <li><a href="/empreendimentos/luzes-do-rio">Luzes do Rio</a></li>
          <li><a href="/empreendimentos/residencial-cartola">Residencial Cartola</a></li>
          <li><a href="/empreendimentos/nova-norte-raizes">Nova Norte Raízes</a></li>
          <li><a href="/empreendimentos/caminhos-da-guanabara">Caminhos da Guanabara</a></li>
          <li><a href="/empreendimentos/farol-da-guanabara">Farol da Guanabara</a></li>
          <li><a href="/empreendimentos/residencial-pixinguinha">Res. Pixinguinha</a></li>
        </ul>
      </div>
      <div class="footer__links">
        <h4>Atendimento</h4>
        <ul>
          <li><a href="/#vantagens">Vantagens MCMV</a></li>
          <li><a href="/#contato">Fale Conosco</a></li>
        </ul>
      </div>
    </div>
    <div class="footer__bottom">
      <div class="container">
        <p>&copy; 2025 Portal Cury – Todos os direitos reservados. CRECI RJ: 00000-J</p>
        <p class="footer__disclaimer">Imagens meramente ilustrativas. Condições sujeitas à aprovação de crédito.</p>
        <p class="footer__disclaimer" style="margin-top:6px">Site desenvolvido por <a href="https://agenciaqao.com.br" target="_blank" rel="noopener" style="color:inherit;text-decoration:underline">agenciaqao.com.br</a></p>
      </div>
    </div>
  </footer>

  <!-- WhatsApp Float -->
  <a href="https://wa.me/5521967019390?text=Olá!%20Tenho%20interesse%20no%20<%= encodeURIComponent(emp.name) %>" class="whatsapp-float" target="_blank" rel="noopener" aria-label="WhatsApp">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    <span>WhatsApp</span>
  </a>

  <!-- WhatsApp Lead Modal -->
  <div class="modal" id="waLeadModal" role="dialog" aria-modal="true" aria-labelledby="waModalTitle">
    <div class="modal__backdrop" id="waModalBackdrop"></div>
    <div class="modal__box" style="max-width:360px;position:relative">
      <button id="waModalClose" style="position:absolute;top:12px;right:16px;background:none;border:none;font-size:1.6rem;cursor:pointer;color:#999;line-height:1" aria-label="Fechar">×</button>
      <div class="modal__icon" style="background:#25d366">
