      </div>
      <h3 id="waModalTitle" style="margin-bottom:6px">Fale pelo WhatsApp</h3>
      <p style="font-size:.9rem;color:#666;margin-bottom:18px">Informe seus dados para atendimento preferencial.</p>
      <form id="waLeadForm" novalidate>
        <div style="margin-bottom:12px">
          <input type="text" id="wa-name" name="name" placeholder="Seu nome completo *" required autocomplete="name"
            style="width:100%;padding:11px 14px;border:1.5px solid #ddd;border-radius:8px;font-size:1rem;box-sizing:border-box" />
        </div>
        <div style="margin-bottom:18px">
          <input type="tel" id="wa-phone" name="phone" placeholder="Seu WhatsApp *" required autocomplete="tel"
            style="width:100%;padding:11px 14px;border:1.5px solid #ddd;border-radius:8px;font-size:1rem;box-sizing:border-box" />
        </div>
        <button type="submit" style="width:100%;padding:13px;background:#25d366;color:#fff;border:none;border-radius:8px;font-size:1rem;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px">
